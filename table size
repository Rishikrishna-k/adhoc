# Re-extract clean tokens from the file list
$tableNames = Get-Content bhi_tables_raw.txt | ForEach-Object {
    $fileName = [System.IO.Path]::GetFileName($_)
    $fileName.Substring(0, $fileName.IndexOf('.csv.gz')).ToLower()
}

# Build comma-separated quoted list for SQL IN clause
$tableListString = ($tableNames | ForEach-Object { "'$_'" }) -join ','

# Run against PostgreSQL
kubectl exec -i <postgres-pod> -n cs-bhi-prod -- psql -U postgres -d postgres -c "
SELECT 
    tablename AS table_name,
    n_live_tup AS row_count,
    pg_size_pretty(pg_total_relation_size(quote_ident(tablename))) AS total_size,
    pg_total_relation_size(quote_ident(tablename)) AS size_bytes
FROM pg_stat_user_tables
WHERE schemaname = 'library'
AND tablename IN ($tableListString)
ORDER BY size_bytes DESC;
" > bhi_tables_report.csv
