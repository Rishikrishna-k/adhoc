kubectl exec -it <mongo-pod> -n cs-bhi-prod -- mongosh creol-api --quiet --eval "
var bundle = db.bundles.findOne({ name: /BHI/i });
var ruleIds = db.bundle_rulesources.distinct('bundleRuleSourceId.ruleId', { bundleId: bundle._id.toString(), deleted: { \$ne: true } });
var tableNames = db.ruletablemappings.distinct('tableName', { ruleId: { \$in: ruleIds }, deleted: { \$ne: true } });
print('tableName,docCount,sizeBytes,storageSizeBytes');
tableNames.forEach(t => {
  var s = db.runCommand({ collStats: 'table_' + t });
  print(t + ',' + s.count + ',' + s.size + ',' + s.storageSize);
});
" > bhi_tables.csv
